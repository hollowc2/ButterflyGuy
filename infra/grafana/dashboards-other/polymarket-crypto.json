              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT\n  ts AS \"Time\",\n  direction AS \"Dir\",\n  ROUND(entry_price::numeric, 3) AS \"Fill\",\n  ROUND(pnl::numeric, 2) AS \"Net PnL\",\n  ROUND(SUM(pnl) OVER (ORDER BY ts ROWS UNBOUNDED PRECEDING)::numeric, 2) AS \"Cum PnL\",\n  CASE WHEN won THEN 'W' ELSE 'L' END AS \"W/L\",\n  ROUND(amount::numeric, 2) AS \"Size\"\nFROM polymarket_trades\nWHERE won IS NOT NULL\n  AND strategy = '$selected_strategy'\n  AND ('$paper' = 'all' OR paper::text = '$paper')\nORDER BY ts DESC\nLIMIT 100",
          "format": "table",
          "refId": "A"
        }
      ]
