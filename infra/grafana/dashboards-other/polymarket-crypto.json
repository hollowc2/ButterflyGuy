    {
      "id": 12,
      "type": "timeseries",
      "title": "Equity Curve \u2014 $selected_strategy",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 14
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT\n  ts AS time,\n  SUM(pnl) OVER (ORDER BY ts) AS cumulative_pnl\nFROM polymarket_trades\nWHERE won IS NOT NULL\n  AND strategy = '$selected_strategy'\n  AND ('$paper' = 'all' OR paper::text = '$paper')\n  AND $__timeFilter(ts)\nORDER BY ts",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "Drawdown \u2014 $selected_strategy",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 10
      },
      "options": {
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 20,
            "fillBelowTo": "drawdown"
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "WITH cum AS (\n  SELECT ts,\n    SUM(pnl) OVER (ORDER BY ts ROWS UNBOUNDED PRECEDING) AS cum_pnl\n  FROM polymarket_trades\n  WHERE won IS NOT NULL\n    AND strategy = '$selected_strategy'\n    AND ('$paper' = 'all' OR paper::text = '$paper')\n    AND $__timeFilter(ts)\n),\npeak AS (\n  SELECT ts, cum_pnl,\n    MAX(cum_pnl) OVER (ORDER BY ts ROWS UNBOUNDED PRECEDING) AS peak_pnl\n  FROM cum\n)\nSELECT ts AS time, cum_pnl - peak_pnl AS drawdown\nFROM peak\nORDER BY ts",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 27,
      "type": "timeseries",
      "title": "Rolling Win Rate (20-trade window) \u2014 $selected_strategy",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 24,
        "h": 12
