      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT\n  strategy AS \"Strategy\",\n  asset AS \"Asset\",\n  COUNT(*) AS \"Trades\",\n  ROUND(AVG(won::int)*100, 1)::float AS \"Win %\",\n  ROUND(SUM(pnl)::numeric, 2)::float AS \"Total P&L\",\n  ROUND(AVG(pnl)::numeric, 3)::float AS \"Avg P&L\",\n  CASE WHEN STDDEV(pnl) = 0 OR STDDEV(pnl) IS NULL THEN NULL\n       ELSE ROUND((AVG(pnl) / STDDEV(pnl) * SQRT(COUNT(*)))::numeric, 2)::float\n  END AS \"Sharpe\",\n  CASE\n    WHEN EXTRACT(EPOCH FROM (NOW() - MAX(ts))) < 3600\n      THEN ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(ts)))/60)::text || 'm ago'\n    WHEN EXTRACT(EPOCH FROM (NOW() - MAX(ts))) < 86400\n      THEN ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(ts)))/3600, 1)::text || 'h ago'\n    ELSE ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(ts)))/86400, 1)::text || 'd ago'\n  END AS \"Last Trade\"\nFROM polymarket_trades\nWHERE won IS NOT NULL\n  AND ('$paper' = 'all' OR paper::text = '$paper')\n  AND strategy ~ '${strategy:pipe}'\n  AND $__timeFilter(ts)\nGROUP BY strategy, asset\nORDER BY \"Total P&L\" DESC",
          "format": "table",
          "refId": "A"
        }
