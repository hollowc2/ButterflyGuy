        ]
      },
      {
        "name": "strategy",
        "label": "Strategy",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "timescaledb"
        },
        "query": "SELECT DISTINCT strategy FROM polymarket_trades WHERE '$active_only' = 'all' OR strategy IN (SELECT name FROM strategies WHERE is_active = true) ORDER BY 1",
        "multi": true,
        "includeAll": true,
        "current": {},
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "selected_strategy",
        "label": "Selected",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "timescaledb"
        },
        "query": "SELECT DISTINCT strategy FROM polymarket_trades WHERE '$active_only' = 'all' OR strategy IN (SELECT name FROM strategies WHERE is_active = true) ORDER BY 1",
        "multi": false,
        "includeAll": false,
        "current": {},
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "paper",
        "label": "Mode",
        "type": "custom",
        "query": "All : all,Paper : true,Live : false",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "All",
          "value": "all"
        },
        "options": [
          {
            "text": "All",
            "value": "all",
            "selected": true
          },
          {
            "text": "Paper",
            "value": "true",
            "selected": false
          },
          {
            "text": "Live",
            "value": "false",
            "selected": false
