{
  "title": "SPX Candidate — 20 Trade Gate",
  "uid": "spx-candidate-gate",
  "tags": ["options", "paper", "candidate"],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-90d", "to": "now"},
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Runtime Up",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "targets": [{"expr": "up{job=\"butterfly_spx_candidate\"}", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}]}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Forward Trades (gate: 20)",
      "datasource": {"type": "postgres", "uid": "timescaledb-spx-candidate"},
      "gridPos": {"x": 4, "y": 0, "w": 5, "h": 4},
      "targets": [{"format": "time_series", "rawQuery": true, "rawSql": "SELECT NOW() AS time, COUNT(*)::float AS value FROM butterfly_trades", "refId": "A"}],
      "fieldConfig": {"defaults": {"min": 0, "max": 20, "decimals": 0}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Win Rate",
      "datasource": {"type": "postgres", "uid": "timescaledb-spx-candidate"},
      "gridPos": {"x": 9, "y": 0, "w": 5, "h": 4},
      "targets": [{"format": "time_series", "rawQuery": true, "rawSql": "SELECT NOW() AS time, COALESCE(100.0 * COUNT(*) FILTER (WHERE pnl > 0) / NULLIF(COUNT(*), 0), 0)::float AS value FROM butterfly_trades WHERE status IN ('CLOSED', 'EXPIRED')", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total P&L",
      "datasource": {"type": "postgres", "uid": "timescaledb-spx-candidate"},
      "gridPos": {"x": 14, "y": 0, "w": 5, "h": 4},
      "targets": [{"format": "time_series", "rawQuery": true, "rawSql": "SELECT NOW() AS time, COALESCE(SUM(pnl * 100 * quantity), 0)::float AS value FROM butterfly_trades WHERE status IN ('CLOSED', 'EXPIRED')", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Open Trades",
      "datasource": {"type": "postgres", "uid": "timescaledb-spx-candidate"},
      "gridPos": {"x": 19, "y": 0, "w": 5, "h": 4},
      "targets": [{"format": "time_series", "rawQuery": true, "rawSql": "SELECT NOW() AS time, COUNT(*)::float AS value FROM butterfly_trades WHERE status='OPEN'", "refId": "A"}],
      "fieldConfig": {"defaults": {"decimals": 0}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Candidate Equity Curve",
      "datasource": {"type": "postgres", "uid": "timescaledb-spx-candidate"},
      "gridPos": {"x": 0, "y": 4, "w": 14, "h": 8},
      "targets": [{"format": "time_series", "rawQuery": true, "rawSql": "SELECT exit_time AS time, SUM(pnl * 100 * quantity) OVER (ORDER BY exit_time) AS \"P&L\" FROM butterfly_trades WHERE status IN ('CLOSED', 'EXPIRED') AND $__timeFilter(exit_time) ORDER BY exit_time", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "currencyUSD", "decimals": 2}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 7,
      "type": "table",
      "title": "Recent Candidate Trades",
      "datasource": {"type": "postgres", "uid": "timescaledb-spx-candidate"},
      "gridPos": {"x": 14, "y": 4, "w": 10, "h": 8},
      "targets": [{"format": "table", "rawQuery": true, "rawSql": "SELECT trade_date, direction, wing_width, center_strike::float, status, exit_reason, (pnl * 100 * quantity)::float AS pnl FROM butterfly_trades ORDER BY entry_time DESC LIMIT 20", "refId": "A"}],
      "fieldConfig": {"defaults": {}, "overrides": []},
      "options": {"showHeader": true}
    }
  ]
}
