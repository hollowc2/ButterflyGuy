          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "NDX Spot Price",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 7,
        "w": 14,
        "x": 0,
        "y": 26
      },
