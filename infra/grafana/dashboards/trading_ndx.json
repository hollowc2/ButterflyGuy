          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, ROUND((ndx.price * (vix.price / 100.0) / SQRT(252))::numeric, 0)::float AS value FROM trades t CROSS JOIN LATERAL (SELECT price FROM spot_prices WHERE underlying = '$VIX' AND ts <= t.entry_time ORDER BY ts DESC LIMIT 1) vix CROSS JOIN LATERAL (SELECT price FROM spot_prices WHERE underlying = 'NDX' AND ts <= t.entry_time ORDER BY ts DESC LIMIT 1) ndx WHERE t.trade_date = CURRENT_DATE AND t.underlying = 'NDX' AND t.status != 'CANCELLED' ORDER BY t.entry_time DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
