      "targets": [
        {
          "expr": "rate(butterfly_chain_snapshots_total{underlying=\"NDX\"}[1h])",
          "legendFormat": "Snapshots/hr"
        }
      ]
    },
    {
      "id": 7,
      "title": "Butterfly Candidates Found",
