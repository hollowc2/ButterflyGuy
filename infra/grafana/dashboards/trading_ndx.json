          },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, sp.price::float AS value FROM trades t CROSS JOIN LATERAL (SELECT price FROM spot_prices WHERE underlying = '$VIX' AND ts <= t.entry_time ORDER BY ts DESC LIMIT 1) sp WHERE t.trade_date = CURRENT_DATE AND t.underlying = 'NDX' AND t.status != 'CANCELLED' ORDER BY t.entry_time DESC LIMIT 1",
