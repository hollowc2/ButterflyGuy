      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, price AS \"NDX\" FROM spot_prices WHERE underlying='NDX' AND $__timeFilter(ts) ORDER BY ts",
          "format": "time_series",
          "legendFormat": "NDX"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT entry_time AS time, lower_strike + entry_price AS \"lower_be\", center_strike AS \"center\", upper_strike - entry_price AS \"upper_be\" FROM trades WHERE trade_date = CURRENT_DATE AND underlying = 'NDX' AND status != 'CANCELLED' ORDER BY entry_time LIMIT 1",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT t.entry_time AS time, sp.price AS \"Entry\" FROM trades t CROSS JOIN LATERAL (  SELECT price FROM spot_prices   WHERE underlying='NDX' AND ts <= t.entry_time   ORDER BY ts DESC LIMIT 1) sp WHERE t.trade_date = CURRENT_DATE AND t.underlying = 'NDX' AND t.status != 'CANCELLED' ORDER BY t.entry_time LIMIT 1",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT t.exit_time AS time, sp.price AS \"Exit\" FROM trades t CROSS JOIN LATERAL (  SELECT price FROM spot_prices   WHERE underlying='NDX' AND ts <= t.exit_time   ORDER BY ts DESC LIMIT 1) sp WHERE t.trade_date = CURRENT_DATE AND t.underlying = 'NDX' AND t.status != 'CANCELLED' AND t.exit_time IS NOT NULL ORDER BY t.entry_time LIMIT 1",
          "format": "time_series"
        }
      ]
