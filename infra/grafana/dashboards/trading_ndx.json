      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 33
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, butterfly_order_fill_duration_seconds_bucket{underlying=\"NDX\"})",
          "legendFormat": "p95 fill time (s)"
        }
