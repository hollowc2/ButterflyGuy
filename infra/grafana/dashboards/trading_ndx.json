{
  "title": "NDX Trading",
  "uid": "butterfly-trading-ndx",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Daily P&L",
      "type": "bargauge",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "butterfly_daily_pnl_dollars{underlying=\"NDX\"}",
          "legendFormat": "Daily P&L ($)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Position Value",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "butterfly_position_value{underlying=\"NDX\"}",
          "legendFormat": "Current Value"
        }
      ]
    },
    {
      "id": 3,
      "title": "Peak vs Current Value",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "butterfly_position_peak_value{underlying=\"NDX\"}",
          "legendFormat": "Peak"
        },
        {
          "expr": "butterfly_position_value{underlying=\"NDX\"}",
          "legendFormat": "Current"
        }
      ]
    },
    {
      "id": 4,
      "title": "Daily Trade Count",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "butterfly_daily_trade_count{underlying=\"NDX\"}",
          "legendFormat": "Trades Today"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Trades",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "expr": "butterfly_trades_active{underlying=\"NDX\"}",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "id": 6,
