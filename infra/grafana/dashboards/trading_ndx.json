            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "decimals": 2
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, price FROM spot_prices WHERE underlying = 'NDX' AND $__timeFilter(ts) ORDER BY time",
          "format": "time_series",
          "refId": "A"
