{
  "title": "Butterfly Performance",
  "uid": "butterfly-performance",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Summary Stats",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Realized P&L",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COALESCE(SUM(pnl), 0)::float AS value FROM trades WHERE status='CLOSED'",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Win Rate",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "displayName": "${__value}%",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 55 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COALESCE(ROUND(100.0 * COUNT(*) FILTER (WHERE pnl > 0) / NULLIF(COUNT(*), 0), 1), 0)::float AS value FROM trades WHERE status='CLOSED'",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Win",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COALESCE(AVG(pnl) FILTER (WHERE pnl > 0), 0)::float AS value FROM trades WHERE status='CLOSED'",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg Loss",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COALESCE(AVG(pnl) FILTER (WHERE pnl < 0), 0)::float AS value FROM trades WHERE status='CLOSED'",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Profit Factor",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 1.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COALESCE(SUM(pnl) FILTER (WHERE pnl > 0) / NULLIF(ABS(SUM(pnl) FILTER (WHERE pnl < 0)), 0), 0)::float AS value FROM trades WHERE status='CLOSED'",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total Trades",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COUNT(*)::float AS value FROM trades WHERE status='CLOSED'",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 16,
      "type": "stat",
      "title": "SPX Spot Price",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 0, "y": 5, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "none",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, price::float AS value FROM spot_prices WHERE underlying='SPX' ORDER BY ts DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "VIX",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 6, "y": 5, "w": 6, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, price::float AS value FROM spot_prices WHERE underlying='$VIX' ORDER BY ts DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "row",
      "title": "Equity Curve",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 1 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Cumulative P&L Over Time",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 0, "y": 11, "w": 24, "h": 8 },
      "options": {
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cumulative_pnl" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 0 }
                  ]
                }
              },
              { "id": "custom.thresholdsStyle", "value": { "mode": "line" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT exit_time AS time, SUM(pnl) OVER (ORDER BY exit_time) AS cumulative_pnl FROM trades WHERE status='CLOSED' AND $__timeFilter(exit_time) ORDER BY exit_time",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Attribution Breakdown",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 19, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "P&L by Direction",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 8 },
      "options": {
        "xField": "direction",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "trade_count" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT direction, COALESCE(SUM(pnl), 0)::float AS total_pnl, COUNT(*)::float AS trade_count FROM trades WHERE status='CLOSED' GROUP BY direction ORDER BY direction",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "barchart",
      "title": "P&L by Wing Width",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 8 },
      "options": {
        "xField": "wing_width",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "trade_count" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT wing_width::text AS wing_width, COALESCE(SUM(pnl), 0)::float AS total_pnl, COUNT(*)::float AS trade_count FROM trades WHERE status='CLOSED' GROUP BY wing_width ORDER BY wing_width",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "type": "barchart",
      "title": "P&L by Exit Reason",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 8 },
      "options": {
        "xField": "exit_reason",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "tooltip": { "mode": "single" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "trade_count" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT COALESCE(exit_reason, 'unknown') AS exit_reason, COALESCE(SUM(pnl), 0)::float AS total_pnl, COUNT(*)::float AS trade_count FROM trades WHERE status='CLOSED' GROUP BY exit_reason ORDER BY total_pnl DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Trade History",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 }
    },
    {
      "id": 15,
      "type": "table",
      "title": "All Trades",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "x": 0, "y": 29, "w": 24, "h": 12 },
      "options": {
        "sortBy": [
          { "displayName": "trade_date", "desc": true }
        ],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pnl" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.displayMode", "value": "color-background" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "green", "value": 0 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "entry_price" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "exit_price" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "peak_value" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "duration_hrs" },
            "properties": [
              { "id": "unit", "value": "h" },
              { "id": "decimals", "value": 1 },
              { "id": "displayName", "value": "duration" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "rawQuery": true,
          "rawSql": "SELECT trade_date, direction, wing_width, center_strike::float AS center_strike, entry_price::float AS entry_price, exit_price::float AS exit_price, pnl::float AS pnl, peak_value::float AS peak_value, exit_reason, ROUND(EXTRACT(EPOCH FROM (exit_time - entry_time)) / 3600.0, 1)::float AS duration_hrs FROM trades WHERE status='CLOSED' ORDER BY trade_date DESC, entry_time DESC",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ]
}
