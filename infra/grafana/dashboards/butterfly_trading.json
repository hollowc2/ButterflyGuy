        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, price AS \"Spot\" FROM spot_prices WHERE underlying='$underlying' AND $__timeFilter(ts) ORDER BY ts",
          "format": "time_series",
          "legendFormat": "Spot"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT sp.ts AS time, (t.lower_strike + t.entry_price)::float AS \"lower_be\", t.center_strike::float AS \"center\", (t.upper_strike - t.entry_price)::float AS \"upper_be\" FROM spot_prices sp CROSS JOIN (SELECT lower_strike, center_strike, upper_strike, entry_price FROM trades WHERE trade_date = CURRENT_DATE AND underlying = '$underlying' AND status != 'CANCELLED' ORDER BY entry_time LIMIT 1) t WHERE sp.underlying = '$underlying' AND $__timeFilter(sp.ts) ORDER BY sp.ts",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT t.entry_time AS time, sp.price AS \"Entry\" FROM trades t CROSS JOIN LATERAL (  SELECT price FROM spot_prices   WHERE underlying='$underlying' AND ts <= t.entry_time   ORDER BY ts DESC LIMIT 1) sp WHERE t.trade_date = CURRENT_DATE AND t.underlying = '$underlying' AND t.status != 'CANCELLED' ORDER BY t.entry_time LIMIT 1",
          "format": "time_series"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT t.exit_time AS time, sp.price AS \"Exit\" FROM trades t CROSS JOIN LATERAL (  SELECT price FROM spot_prices   WHERE underlying='$underlying' AND ts <= t.exit_time   ORDER BY ts DESC LIMIT 1) sp WHERE t.trade_date = CURRENT_DATE AND t.underlying = '$underlying' AND t.status != 'CANCELLED' AND t.exit_time IS NOT NULL ORDER BY t.entry_time LIMIT 1",
          "format": "time_series"
        }
      ]
    },
