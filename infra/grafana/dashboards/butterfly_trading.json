{
  "title": "Butterfly Trading",
  "uid": "butterfly-trading",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "underlying",
        "label": "Underlying",
        "type": "custom",
        "query": "SPX : SPX,NDX : NDX,XSP : XSP",
        "current": { "text": "SPX", "value": "SPX" },
        "options": [
          { "text": "SPX", "value": "SPX", "selected": true },
          { "text": "NDX", "value": "NDX", "selected": false },
          { "text": "XSP", "value": "XSP", "selected": false }
        ],
        "multi": false,
        "includeAll": false,
        "hide": 0,
        "refresh": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Daily P&L",
      "type": "bargauge",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "butterfly_daily_pnl_dollars{underlying=\"$underlying\"}",
          "legendFormat": "Daily P&L ($)"
        }
      ]
    },
    {
      "id": 2,
      "title": "Position Value",
      "type": "gauge",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "butterfly_position_value{underlying=\"$underlying\"}",
          "legendFormat": "Current Value"
        }
      ]
    },
    {
      "id": 3,
      "title": "Peak vs Current Value",
      "type": "timeseries",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "butterfly_position_peak_value{underlying=\"$underlying\"}",
          "legendFormat": "Peak"
        },
        {
          "expr": "butterfly_position_value{underlying=\"$underlying\"}",
          "legendFormat": "Current"
        }
      ]
    },
    {
      "id": 4,
      "title": "Daily Trade Count",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "butterfly_daily_trade_count{underlying=\"$underlying\"}",
          "legendFormat": "Trades Today"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Trades",
      "type": "stat",
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "expr": "butterfly_trades_active{underlying=\"$underlying\"}",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "id": 6,
      "title": "Chain Snapshots (1h rate)",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "expr": "rate(butterfly_chain_snapshots_total{underlying=\"$underlying\"}[1h])",
          "legendFormat": "Snapshots/hr"
        }
      ]
    },
    {
      "id": 7,
      "title": "Butterfly Candidates Found",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 30
      },
      "targets": [
        {
          "expr": "butterfly_candidates_found{underlying=\"$underlying\"}",
          "legendFormat": "Candidates"
        }
      ]
    },
    {
      "id": 8,
      "title": "Order Fill Duration (p95)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 49
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, butterfly_order_fill_duration_seconds_bucket{underlying=\"$underlying\"})",
          "legendFormat": "p95 fill time (s)"
        }
      ]
    },
    {
      "id": 9,
      "title": "Schwab API Errors",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 88
      },
      "targets": [
        {
          "expr": "rate(butterfly_schwab_api_errors_total[5m])",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "$underlying Spot Price",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 7,
        "w": 14,
        "x": 0,
        "y": 42
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, price FROM spot_prices WHERE underlying = '$underlying' AND $__timeFilter(ts) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "VIX",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 7,
        "w": 10,
        "x": 14,
        "y": 42
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "decimals": 2
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT ts AS time, price FROM spot_prices WHERE underlying = '$VIX' AND $__timeFilter(ts) ORDER BY time",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Rows in Last Snapshot",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 49
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 400
              },
              {
                "color": "green",
                "value": 460
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "butterfly_chain_snapshot_rows{underlying=\"$underlying\"}",
          "legendFormat": "Rows"
        }
      ]
    },
    {
      "id": 13,
      "title": "DB Snapshots Today",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 49
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, COUNT(DISTINCT snapshot_time)::float AS value FROM option_chain_snapshots WHERE snapshot_time::date = CURRENT_DATE AND underlying = '$underlying'",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Snapshot Collect Duration",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 49
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(butterfly_chain_snapshot_duration_seconds_bucket{underlying=\"$underlying\"}[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(butterfly_chain_snapshot_duration_seconds_bucket{underlying=\"$underlying\"}[5m]))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "Today's Trade",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 53,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 16,
      "type": "stat",
      "title": "Center Strike",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 6,
        "h": 3
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, center_strike::float AS value FROM trades WHERE trade_date = CURRENT_DATE AND underlying = '$underlying' AND status != 'CANCELLED' ORDER BY entry_time DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 17,
      "type": "stat",
