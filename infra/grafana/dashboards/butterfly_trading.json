              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, entry_price::float AS value FROM trades WHERE trade_date = CURRENT_DATE AND underlying = '$underlying' AND status != 'CANCELLED' ORDER BY entry_time DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "Max Profit / Spread",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "gridPos": {
        "x": 18,
        "y": 54,
        "w": 6,
        "h": 3
