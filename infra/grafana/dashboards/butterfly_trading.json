          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawQuery": true,
          "rawSql": "SELECT NOW() AS time, (wing_width - entry_price)::float AS value FROM trades WHERE trade_date = CURRENT_DATE AND underlying = '$underlying' AND status != 'CANCELLED' ORDER BY entry_time DESC LIMIT 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
