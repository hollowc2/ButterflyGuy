{
  "uid": "turtlequant-monitor",
  "title": "TurtleQuant Strategy Monitor",
  "tags": [
    "turtlequant",
    "trading",
    "polymarket"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "strategy",
        "label": "Strategy",
        "type": "custom",
        "query": "TurtleQuant : turtlequant,SlowQuant : slowquant",
        "multi": false,
        "includeAll": false,
        "current": {
          "text": "TurtleQuant",
          "value": "turtlequant",
          "selected": true
        },
        "options": [
          {
            "text": "TurtleQuant",
            "value": "turtlequant",
            "selected": true
          },
          {
            "text": "SlowQuant",
            "value": "slowquant",
            "selected": false
          }
        ],
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "NAV",
      "description": "Current net asset value in USD",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "text": {}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1000
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "turtlequant_nav_usd{strategy=\"$strategy\"}",
          "instant": true,
          "range": false,
          "legendFormat": "",
          "refId": "A"
