        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "Size ($)",
              "Value #B": "Edge at Entry",
              "Value #C": "Age (h)",
              "Value #D": "Model Prob",
              "market_id": "Market ID",
              "asset": "Asset",
              "option_type": "Type",
              "strategy": "",
              "Time": ""
