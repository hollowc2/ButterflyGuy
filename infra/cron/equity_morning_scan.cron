# Equity morning scan — 6:00 AM Pacific, weekdays.
# Install: crontab -l 2>/dev/null | grep -v run_morning_scan | cat - infra/cron/equity_morning_scan.cron | crontab -
CRON_TZ=America/Los_Angeles
0 6 * * 1-5 cd /opt/butterflyguy && /opt/butterflyguy/.venv/bin/python src/butterfly_guy/scripts/run_morning_scan.py --log-level WARNING >> /opt/butterflyguy/equity_morning_scan.log 2>&1
